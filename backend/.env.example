POSTGRES_DB=autologbook
POSTGRES_USER=alb
POSTGRES_PASSWORD=alb_dev_password
DATABASE_URL=postgresql+asyncpg://alb:alb_dev_password@postgres:5432/autologbook
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=autologbook-dev
SECRET_KEY=replace-with-a-long-random-secret
REGISTRATION_SECRET=change-me-before-deployment
CONTEXT_ID_HMAC_KEY=change-me-before-deployment
DATA_SERVICE_CURRENT_VERSION=0.1.0
TOKEN_LOCAL_VALIDATION=true
JWT_ALGORITHM=RS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
DATA_SERVICE_TOKEN_TTL_HOURS=8
HEARTBEAT_INTERVAL_SECONDS=30
JWT_PRIVATE_KEY_PATH=/tmp/autologbook/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/tmp/autologbook/jwt_public.pem
CORS_ALLOWED_ORIGINS=["*"]
